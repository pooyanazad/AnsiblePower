# AnsiblePower environment variables
# Copy this file to .env and adjust values before running docker compose up

# Secret key for Flask session encryption (CHANGE THIS in production)
FLASK_SECRET_KEY=changeme-to-a-random-string

# Enable Flask debug mode (set to "true" for development)
FLASK_DEBUG=false

# Path to ansible-playbook binary (auto-detected if not set)
# ANSIBLE_PLAYBOOK_BIN=ansible-playbook
